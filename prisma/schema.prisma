// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id             String   @id
  track          String
  date           DateTime
  resultsJsonUrl String   @unique
  server         String
  processed      Boolean  @default(false)
  
  // Relacje
  eloHistory     EloHistory[]
}

model Driver {
  guid       String   @id // Steam GUID jest unikalny i stały
  mainName   String   // Główna/aktualna nazwa
  altNames   String?  // Nazwy oddzielone przecinkami
  currentElo Float    @default(1200.0) // Startowe ELO
  combo      Int      @default(0)      // 🟢 Seria wyścigów z rzędu podnosząca zyski punktowe
  
  eloHistory EloHistory[]
}

// 3. Tabela Historycznego ELO (Cross Table)
model EloHistory {
  id         Int      @id @default(autoincrement())
  
  // Relacja do Eventu
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id])
  
  // Relacja do Kierowcy
  driverGuid String
  driver     Driver   @relation(fields: [driverGuid], references: [guid])
  
  eloBefore  Float    // ELO przed wyścigiem
  eloAfter   Float    // ELO po wyścigu
  eloChange  Float    // Różnica (np. +15, -10)
  position   Int      // Zajęte miejsce w tym konkretnym wyścigu
  combo      Int      @default(0)
  
  createdAt  DateTime @default(now())

  @@index([driverGuid])
  @@index([eventId])
}