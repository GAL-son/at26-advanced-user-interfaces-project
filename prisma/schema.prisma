// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // provider = "sqlite" // For local developement
  provider = "postgresql"
  url       = env("POSTGRES_URL")
  // directUrl = env("DIRECT_URL") // will see if needed
}

model Event {
  id             String   @id
  name           String
  track          String
  date           DateTime
  laps           Int?
  time           Int?

  server         String
  processed      Boolean  @default(false)
  
  raceResult     RaceResult[]
}

model Driver {
  guid       String   @id
  mainName   String
  altNames   String?
  currentElo Float    @default(1000.0)
  combo      Int      @default(0)
  
  raceResult RaceResult[]
}

model RaceResult {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id])
  driverGuid String
  driver     Driver   @relation(fields: [driverGuid], references: [guid])
  
  // Dane z wyścigu
  started    Int
  position   Int
  car        String
  laps       Int
  totalTime  Float
  bestLap    Float
  gap        String?

  eloBefore  Float?    
  eloAfter   Float?    
  combo      Int?     @default(0)
  eloAlg     String?

  createdAt  DateTime @default(now())

  @@index([driverGuid])
  @@index([eventId])
}